generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum NicheStatus {
  PENDING
  EXPANDING
  ENRICHING
  CLASSIFYING
  SCORING
  DONE
  FAILED
}

model Niche {
  id            String         @id @default(cuid())
  seedTerm      String
  status        NicheStatus    @default(PENDING)
  error         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  keywords      Keyword[]
  opportunities Opportunity[]
  convRate      Float          @default(0.015)
  ltvCacRatio   Float          @default(3.0)
  /// Legacy field (unused) — demand score no longer uses buyer weights
  buyerWeights  Json?
  /// Optional pass/fail rubric thresholds for decision support
  rubricConfig  Json?
}

model Keyword {
  id            String        @id @default(cuid())
  nicheId       String
  niche         Niche         @relation(fields: [nicheId], references: [id], onDelete: Cascade)
  term          String
  searchVolume  Int?
  cpc           Float?
  competition   Float?
  monthlyTrend  Json?
  raw           Json?
  opportunityId String?
  opportunity   Opportunity?  @relation(fields: [opportunityId], references: [id])
  createdAt     DateTime      @default(now())

  @@unique([nicheId, term])
  @@index([nicheId])
  @@index([term])
}

model Opportunity {
  id                 String    @id @default(cuid())
  nicheId            String
  niche              Niche     @relation(fields: [nicheId], references: [id], onDelete: Cascade)
  productDescription String
  buyerType          String
  intent             String
  painSeverity       Int
  reasoning          String
  /// AI second-pass: concrete product you could ship
  productAngle       String?
  /// AI second-pass: e.g. SaaS subscription, affiliate, lead-gen
  monetizationModel  String?
  /// AI second-pass: narrow entry wedge
  wedge              String?
  totalVolume        Int
  avgCpc             Float
  avgCompetition     Float
  impliedCac         Float
  annualPriceFloor   Float
  monthlyPriceFloor  Float
  demandScore        Float
  /// Organic SERP snapshot for the theme's top keyword (JSON array).
  serpSnapshot       Json?
  serpQuery          String?
  serpFetchedAt      DateTime?
  /// 0..1 organic softness derived from serpSnapshot (higher = easier).
  organicSoftness    Float?
  pinned             Boolean   @default(false)
  notes              String    @default("")
  reviewStatus       String    @default("none") // none | watching | building | passed
  keywords           Keyword[]
  createdAt          DateTime  @default(now())

  @@index([nicheId])
  @@index([pinned])
}

/// Seeds the operator permanently dismissed from Recommended seeds.
model RejectedSeed {
  id        String   @id @default(cuid())
  term      String   @unique
  reason    String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

/// Seeds already surfaced in Recommended seeds — never suggest again.
model ShownRecommendedSeed {
  id        String   @id @default(cuid())
  term      String   @unique
  /// default | low_cpc | mixed — last mode that showed this term
  mode      String   @default("default")
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model ApiCostLog {
  id        String   @id @default(cuid())
  provider  String
  endpoint  String
  cost      Float
  nicheId   String?
  meta      Json?
  createdAt DateTime @default(now())

  @@index([nicheId])
  @@index([createdAt])
}

/// Operator-owned website / product whose keywords are tracked separately from niche research.
model TrackedSite {
  id        String           @id @default(cuid())
  name      String
  domain    String?
  notes     String           @default("")
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  keywords  TrackedKeyword[]

  @@index([createdAt])
}

/// Keywords you already rank for / target on a site, plus idea children expanded from them.
model TrackedKeyword {
  id             String          @id @default(cuid())
  siteId         String
  site           TrackedSite     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  term           String
  /// manual | idea | imported
  source         String          @default("manual")
  /// tracking | idea | targeting | dismissed
  status         String          @default("tracking")
  /// When source=idea, the tracked keyword that spawned this suggestion.
  parentId       String?
  parent         TrackedKeyword? @relation("KeywordIdeas", fields: [parentId], references: [id], onDelete: SetNull)
  ideas          TrackedKeyword[] @relation("KeywordIdeas")
  searchVolume   Int?
  cpc            Float?
  competition    Float?
  monthlyTrend   Json?
  raw            Json?
  notes          String          @default("")
  lastEnrichedAt DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([siteId, term])
  @@index([siteId])
  @@index([status])
  @@index([parentId])
}
