generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum NicheStatus {
  PENDING
  EXPANDING
  ENRICHING
  CLASSIFYING
  SCORING
  DONE
  FAILED
}

model Niche {
  id            String         @id @default(cuid())
  seedTerm      String
  status        NicheStatus    @default(PENDING)
  error         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  keywords      Keyword[]
  opportunities Opportunity[]
  convRate      Float          @default(0.015)
  ltvCacRatio   Float          @default(3.0)
  /// Legacy field (unused) — demand score no longer uses buyer weights
  buyerWeights  Json?
  /// Optional pass/fail rubric thresholds for decision support
  rubricConfig  Json?
}

model Keyword {
  id            String        @id @default(cuid())
  nicheId       String
  niche         Niche         @relation(fields: [nicheId], references: [id], onDelete: Cascade)
  term          String
  searchVolume  Int?
  cpc           Float?
  competition   Float?
  monthlyTrend  Json?
  raw           Json?
  opportunityId String?
  opportunity   Opportunity?  @relation(fields: [opportunityId], references: [id])
  createdAt     DateTime      @default(now())

  @@unique([nicheId, term])
  @@index([nicheId])
  @@index([term])
}

model Opportunity {
  id                 String    @id @default(cuid())
  nicheId            String
  niche              Niche     @relation(fields: [nicheId], references: [id], onDelete: Cascade)
  productDescription String
  buyerType          String
  intent             String
  painSeverity       Int
  reasoning          String
  totalVolume        Int
  avgCpc             Float
  avgCompetition     Float
  impliedCac         Float
  annualPriceFloor   Float
  monthlyPriceFloor  Float
  demandScore        Float
  pinned             Boolean   @default(false)
  notes              String    @default("")
  reviewStatus       String    @default("none") // none | watching | building | passed
  keywords           Keyword[]
  createdAt          DateTime  @default(now())

  @@index([nicheId])
  @@index([pinned])
}

model ApiCostLog {
  id        String   @id @default(cuid())
  provider  String
  endpoint  String
  cost      Float
  nicheId   String?
  meta      Json?
  createdAt DateTime @default(now())

  @@index([nicheId])
  @@index([createdAt])
}
